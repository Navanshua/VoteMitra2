# ═══════════════════════════════════════════════════════════════════
#  VoterMitra — Environment Variables
#  Copy this file to .env and fill in all values before running.
#  cp .env.example .env
#
#  HOW TO GET EACH KEY is documented inline below.
# ═══════════════════════════════════════════════════════════════════

# ── 1. GCP Project ──────────────────────────────────────────────────
#  The GCP project ID you created for VoterMitra.
#  Find it at: https://console.cloud.google.com → project selector
GCP_PROJECT_ID=votemitra-494915
GCP_REGION=asia-south1

# ── 2. Gemini / Vertex AI ───────────────────────────────────────────
#  Option A (Easiest — free tier available):
#    Go to https://aistudio.google.com/app/apikey → Create API Key
#    Paste the key below as GEMINI_API_KEY
#
#  Option B (Production — uses Application Default Credentials):
#    Leave GEMINI_API_KEY empty and set GOOGLE_APPLICATION_CREDENTIALS
#    The backend will use Vertex AI via ADC automatically.
#
VERTEX_AI_LOCATION=asia-south1
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# ── 3. Google Cloud REST API Key ────────────────────────────────────
#  Used by the backend for Google Cloud Translation API v2.
#  How to get:
#    1. Go to https://console.cloud.google.com/apis/credentials
#    2. Click "Create Credentials" → "API Key"
#    3. Restrict it to: Cloud Translation API
#    4. Copy the key here
#
#  NOTE: This is the same key as VITE_GCP_API_KEY if you use the
#  same GCP project for Firebase and Translation API.
GCP_API_KEY=your_gcp_api_key_here

# ── 4. Firebase / Google Identity Platform ──────────────────────────
#  How to get:
#    1. Go to https://console.firebase.google.com
#    2. Add or select your GCP project (votermitra-2026)
#    3. Go to Project Settings → "Your apps" → Add Web App
#    4. Copy the values from the firebaseConfig object shown
#

VITE_GCP_API_KEY=your_firebase_web_api_key_here
VITE_GCP_PROJECT_ID=votemitra-494915
VITE_AUTH_DOMAIN=votemitra-494915.firebaseapp.com
VITE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_APP_ID=your_app_id_here

#  After getting the above, also:
#    - Enable Google Sign-in:
#        Firebase Console → Authentication → Sign-in method → Google → Enable
#    - Add your frontend URL to Authorized Domains:
#        Firebase Console → Authentication → Settings → Authorized domains

# ── 5. Backend URL (frontend uses this to reach the API) ───────────
#  Local development:
VITE_BACKEND_URL=http://localhost:8000
#
#  After Cloud Run deployment, update to your deployed backend URL:
#  VITE_BACKEND_URL=https://votermitra-backend-xxxxxxxx-as.a.run.app

# ── 6. Dialogflow CX (optional — for advanced chatbot flows) ────────
#  Leave empty if not using Dialogflow. The Mitra chatbot works
#  with just Gemini (GEMINI_API_KEY above) without Dialogflow.
#  How to get:
#    1. https://dialogflow.cloud.google.com/cx
#    2. Create an agent → copy the Agent ID from the URL
DIALOGFLOW_AGENT_ID=ef12b9d3-6dfc-4a34-ad8f-4695ce5f70a5
DIALOGFLOW_LOCATION=global

# ── 7. Local GCP Authentication (Application Default Credentials) ───
#  Required for local backend development to access Firestore,
#  Vertex AI, etc. WITHOUT a service account key file.
#
#  Setup steps:
#    1. Install gcloud CLI: https://cloud.google.com/sdk/docs/install
#    2. Run: gcloud auth application-default login
#    3. Run: gcloud config set project votermitra-2026
#    4. The credentials file is saved automatically. Set its path below:
#
#  Windows path example:
#    C:\Users\YourName\AppData\Roaming\gcloud\application_default_credentials.json
#  Mac/Linux path example:
#    /Users/yourname/.config/gcloud/application_default_credentials.json
#
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\navan\AppData\Roaming\gcloud\application_default_credentials.json

# ── 8. Cloud Run Deployment URLs (filled after first deploy) ────────
#  Leave empty during initial setup. Fill after running deploy.yml CI/CD
#  or the manual gcloud run deploy commands in README.md
BACKEND_CLOUD_RUN_URL=
FRONTEND_URL=

# ── 9. CORS (backend) ───────────────────────────────────────────────
#  Comma-separated list of allowed frontend origins.
#  Default: allow all (*) — tighten in production.
#  Example: https://votermitra-frontend-xxxx-as.a.run.app
ALLOWED_ORIGINS=*
